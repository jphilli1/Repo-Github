{
  "_comment": "[EXACT] — Split-RAG Document Extractor Extraction Rules v1.0.0",

  "header_detection": {
    "all_caps_ratio": 0.80,
    "max_len": 100,
    "min_len": 3,
    "numbered_heading_regex": "^\\d+\\.(?:\\d+\\.)*\\s+",
    "additional_patterns": [
      "^Chapter\\s+\\d+",
      "^Section\\s+\\d+",
      "^Appendix\\s+[A-Z]",
      "^Exhibit\\s+\\d+"
    ]
  },

  "xlsx_table_detection": {
    "header_heuristics": {
      "check_formatting": false,
      "max_numeric_ratio": 0.3,
      "min_columns": 2,
      "min_rows": 2
    }
  },

  "content_filtering": {
    "min_text_length": 10,
    "skip_patterns": [
      "^Page\\s+\\d+\\s*(of\\s+\\d+)?$",
      "^\\d+$",
      "^(CONFIDENTIAL|DRAFT|INTERNAL)$"
    ],
    "low_priority_sections": [
      "Table of Contents",
      "Index",
      "Appendix"
    ]
  },

  "image_classification": {
    "thresholds": {
      "chart_min": 0.15,
      "diagram_min": 0.10,
      "photo_max": 0.08
    },
    "min_width": 50,
    "min_height": 50,
    "max_width": 3000,
    "max_height": 3000
  },

  "confidence_adjustments": {
    "base_scores": {
      "docling": 0.95,
      "pdfplumber": 0.85,
      "office_native": 0.90
    },
    "heuristic_header_penalty": 0.10,
    "warning_penalty_per_warning": 0.05,
    "warning_penalty_max": 0.15,
    "malformed_table_penalty": 0.10,
    "minimum_confidence": 0.50
  }
}
